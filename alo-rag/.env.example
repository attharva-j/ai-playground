# Required API Keys for ALO RAG System
# Note: The server loads the .env file from the workspace root directory
# (one level above alo-rag/), not from this directory.

# OpenAI API key for GPT models (generation + intent routing)
OPENAI_API_KEY=your-openai-api-key-here

# Voyage AI API key for voyage-3 embeddings
VOYAGE_API_KEY=your-voyage-api-key-here
