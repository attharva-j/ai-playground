# ============================================================================
# AgentCore MCP Server - Environment Configuration
# ============================================================================

# ----------------------------------------------------------------------------
# AWS Configuration (Required for AWS features)
# ----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# ----------------------------------------------------------------------------
# AWS Services Configuration
# ----------------------------------------------------------------------------
# Bedrock
GUARDRAIL_ID=your-guardrail-id
GUARDRAIL_VERSION=DRAFT

# S3
S3_BUCKET=your-s3-bucket-name
PRESIGNED_URL_EXPIRY=3600

# DynamoDB (Optional - for audit logging)
DDB_AUDIT_TABLE=agentcore-audit-table

# ----------------------------------------------------------------------------
# Logging Configuration
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO
ENABLE_CLOUDWATCH_LOGS=false

# ----------------------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# ----------------------------------------------------------------------------
# SharePoint Configuration (Optional - for SharePoint features)
# Uses AWS Bedrock AgentCore Identity OAuth2 Credential Provider
# ----------------------------------------------------------------------------

# AWS Credential Provider Configuration
# Provider name created in AWS (see SHAREPOINT_AWS_CREDENTIAL_PROVIDER_SETUP.md)
SHAREPOINT_PROVIDER_NAME=microsoft-oauth-provider

# OAuth2 Callback URL from AWS Credential Provider (REQUIRED)
# Get this from: aws bedrock-agentcore-control create-oauth2-credential-provider
# Format: https://bedrock-agentcore.us-east-1.amazonaws.com/identities/oauth2/callback/...
SHAREPOINT_CALLBACK_URL=your-callback-url-from-aws

# OAuth2 Flow Type (default: USER_FEDERATION for delegated permissions)
SHAREPOINT_AUTH_FLOW=USER_FEDERATION

# SharePoint Site URL (REQUIRED if using SharePoint)
SHAREPOINT_SITE_URL=https://yourtenant.sharepoint.com/sites/yoursite

# Microsoft Graph API Scopes (comma-separated, optional)
# Default scopes: Sites.Read.All, Files.Read.All
SHAREPOINT_SCOPES=https://graph.microsoft.com/Sites.Read.All,https://graph.microsoft.com/Files.Read.All

# ----------------------------------------------------------------------------
# Notes:
# ----------------------------------------------------------------------------
# 1. Copy this file to .env and fill in your actual values
# 2. Never commit .env file to version control
# 3. SharePoint configuration is optional - if not provided, SharePoint tools will be disabled
# 4. For SharePoint setup with AWS Credential Provider, see: SHAREPOINT_AWS_CREDENTIAL_PROVIDER_SETUP.md
# 5. Create AWS OAuth2 Credential Provider first:
#    aws bedrock-agentcore-control create-oauth2-credential-provider \
#      --name "microsoft-oauth-provider" \
#      --credential-provider-vendor "MicrosoftOauth2" \
#      --oauth2-provider-config-input '{"microsoftOauth2ProviderConfig": {...}}'
# 6. Required Azure AD API permissions for SharePoint (Delegated):
#    - Sites.Read.All - Read items in all site collections
#    - Files.Read.All - Read files in all site collections
#    - User.Read - Sign in and read user profile