resource "aws_quicksight_user_custom_permission" "creator" {
  for_each               = data.aws_identitystore_user.creator_idc_user
  user_name              = each.value.user_name
  custom_permissions_name = aws_quicksight_custom_permissions.creator.custom_permissions_name
}

resource "aws_quicksight_role_custom_permission" "reader_pro" {
  role                    = "READER_PRO"
  custom_permissions_name = aws_quicksight_custom_permissions.general.custom_permissions_name
}
