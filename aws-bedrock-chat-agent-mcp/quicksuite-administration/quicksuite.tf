resource "aws_quicksight_account_subscription" "this" {
  aws_account_id = data.aws_caller_identity.current.account_id
  region         = data.aws_region.current.region

  account_name          = "${local.account_name}-${local.environment}"
  authentication_method = "IAM_IDENTITY_CENTER"
  edition               = "ENTERPRISE"
  notification_email    = "DL_AWS_ORGANIZATION+${upper(local.account_name)}.${upper(local.environment)}@<your-domain.com>"

  iam_identity_center_instance_arn = one(data.aws_ssoadmin_instances.current.arns)
  admin_pro_group                  = ["AWS PlatformAdmin"]

  lifecycle {
    ignore_changes = [
      account_name,
      notification_email,
    ]
  }
}

resource "aws_quicksight_account_settings" "this" {
  aws_account_id = aws_quicksight_account_subscription.this.aws_account_id
  region         = aws_quicksight_account_subscription.this.region

  termination_protection_enabled = true
}

resource "aws_quicksight_role_membership" "role_groups" {
  for_each = merge([
    for role, groups in local.role_groups : {
      for group in groups : "${role}|${group}" => {
        role  = upper(role)
        group = group
      }
    }
  ]...)

  member_name = each.value.group
  role        = upper(each.value.role)
}

